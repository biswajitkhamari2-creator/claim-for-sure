# ===== Database =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=claimforsure
DB_USER=root
DB_PASS=

# ===== JWT =====
# Generate a long random string: `openssl rand -hex 64`
JWT_SECRET=change-me-to-a-long-random-string
JWT_ISSUER=claimforsure
JWT_TTL_SECONDS=86400

# ===== App =====
APP_ENV=production
APP_URL=https://claimforsure.in
FRONTEND_URL=https://claimforsure.in
# Comma separated origins allowed for CORS
CORS_ALLOWED_ORIGINS=https://claimforsure.in,http://localhost:8080

# ===== Uploads =====
# Absolute path OR relative to php-backend/. Must be writable by PHP.
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_EXTS=pdf,jpg,jpeg,png,doc,docx

# ===== Mail (PHPMailer SMTP) =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@claimforsure.in
MAIL_FROM_NAME="ClaimForSure"
